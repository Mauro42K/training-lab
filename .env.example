# PostgreSQL DSN for API runtime and Alembic migrations
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/training_lab

# Initial API key bootstrap secret (used in upcoming auth block)
TRAINING_LAB_API_KEY=replace-with-long-random-token

# Maximum workouts accepted per ingest request (used in upcoming ingest block)
INGEST_MAX_BATCH_SIZE=500
